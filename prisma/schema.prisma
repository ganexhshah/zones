generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  password      String?
  passwordHash  String?
  name          String?
  avatar        String?
  googleId      String?   @unique
  authProvider  String    @default("email")
  walletBalance Float     @default(0)
  coinBalance   Int       @default(0)
  freeEntryTokens Int     @default(0)
  availableBalance Decimal @default(0) @db.Decimal(18, 2)
  lockedBalance   Decimal @default(0) @db.Decimal(18, 2)
  isVerified    Boolean   @default(false)
  isBlocked     Boolean   @default(false)
  blockReason   String?
  suspendedUntil DateTime?
  unblockRequestStatus String @default("NONE") // NONE | PENDING | APPROVED | REJECTED
  unblockRequestMessage String?
  unblockRequestedAt DateTime?
  unblockReviewNote String?
  unblockReviewedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  gameIds       GameId[]
  tournaments   TournamentParticipant[]
  transactions  Transaction[]
  pushTokens    UserPushToken[]
  notifications UserNotification[]
  blockedUsers  BlockedUser[] @relation("BlockedBy")
  blockedBy     BlockedUser[] @relation("Blocked")
  ownedTeams    Team[]        @relation("TeamCaptain")
  teamMemberships TeamMember[]
  registrations TournamentRegistration[]
  resultSubmissions MatchResultSubmission[] @relation("ResultSubmittedBy")
  disputesRaised TournamentDispute[] @relation("DisputeRaisedBy")
  payouts TournamentPayout[]
  customMatchesCreated CustomMatch[] @relation("CustomMatchCreator")
  customMatchJoinRequests CustomMatchJoinRequest[] @relation("CustomMatchJoinRequester")
  customMatchJoinReviews CustomMatchJoinRequest[] @relation("CustomMatchJoinReviewer")
  customMatchParticipants CustomMatchParticipant[]
  customMatchResultsSubmitted CustomMatchResultSubmission[] @relation("CustomMatchResultSubmitter")
  customMatchResultsReviewed CustomMatchResultSubmission[] @relation("CustomMatchResultReviewer")
  customMatchesWon CustomMatchResultSubmission[] @relation("CustomMatchResultWinner")
  broadcastsSent BroadcastNotification[] @relation("BroadcastCreatedBy")
  matchesCreated Match[] @relation("MatchCreator")
  matchesJoined Match[] @relation("MatchJoiner")
  joinRequests JoinRequest[]
  walletLedger WalletLedger[]
  sentChatMessages ChatMessage[]
  fraudFlags FraudFlag[]
  refreshTokens RefreshToken[]
  matchLogs MatchLog[] @relation("PerformedBy")
  resultClaimsSubmitted MatchResultClaim[] @relation("ResultClaimSubmitter")
  resultClaimsAsWinner MatchResultClaim[] @relation("ResultClaimWinner")
  rewardState UserRewardState?
  rewardSpins RewardSpin[]
  rewardAudits RewardAudit[]
  popupDismissals BroadcastPopupDismissal[]
  subAdminProfile SubAdmin? @relation("SubAdminUser")
  subAdminsCreated SubAdmin[] @relation("SubAdminCreator")
}

model SubAdmin {
  id              String   @id @default(cuid())
  userId          String   @unique
  createdByUserId String?
  permissions     Json
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation("SubAdminUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("SubAdminCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([isActive, createdAt])
}

enum MatchStatus {
  OPEN
  PENDING_APPROVAL
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum EscrowStatus {
  LOCKED
  RELEASED
  REFUNDED
}

enum WalletLedgerType {
  LOCK
  UNLOCK
  DEBIT
  CREDIT
  REFUND
  WIN
  FEE
}

model GameId {
  id          String   @id @default(cuid())
  userId      String
  gameName    String
  gameId      String
  inGameName  String?
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, gameName])
}

model Tournament {
  id            String    @id @default(cuid())
  title         String
  game          String
  mode          String    @default("SOLO")
  format        String    @default("BR_LEAGUE")
  region        String?
  entryFee      Float
  prizePool     Float
  currency      String    @default("NPR")
  maxPlayers    Int
  roomSize      Int?
  startTime     DateTime
  registrationOpenAt DateTime?
  registrationCloseAt DateTime?
  checkinOpenAt DateTime?
  checkinCloseAt DateTime?
  rulesText     String?
  scoringConfig Json?
  proofRequired Boolean   @default(true)
  disputeWindowMinutes Int @default(15)
  refundRules   String?
  status        String    @default("upcoming")
  imageUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  participants  TournamentParticipant[]
  teams         Team[]
  registrations TournamentRegistration[]
  matches       TournamentMatch[]
  leaderboardEntries TournamentLeaderboardEntry[]
  disputes      TournamentDispute[]
  payouts       TournamentPayout[]
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  userId       String
  tournamentId String
  rank         Int?
  prize        Float?
  joinedAt     DateTime   @default(now())
  
  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  
  @@unique([userId, tournamentId])
}

model Team {
  id          String   @id @default(cuid())
  tournamentId String?
  name        String
  type        String   // DUO | SQUAD
  region      String?
  captainId   String
  inviteCode  String?  @unique
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tournament  Tournament? @relation(fields: [tournamentId], references: [id])
  captain     User        @relation("TeamCaptain", fields: [captainId], references: [id])
  members     TeamMember[]
  registrations TournamentRegistration[]

  @@index([captainId])
  @@index([tournamentId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId     String
  userId     String
  role      String   @default("MEMBER") // CAPTAIN | MEMBER
  status    String   @default("ACTIVE") // ACTIVE | LEFT | INVITED
  joinedAt   DateTime @default(now())

  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TournamentRegistration {
  id             String   @id @default(cuid())
  tournamentId    String
  userId          String?
  teamId          String?
  paid           Boolean  @default(false)
  status         String   @default("PENDING") // PENDING | APPROVED | CHECKED_IN | NO_SHOW | DISQUALIFIED | REJECTED
  seed           Int?
  approvedAt     DateTime?
  checkedInAt    DateTime?
  checkinStatus  String   @default("PENDING") // PENDING | CHECKED_IN | NO_SHOW
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  team           Team?      @relation(fields: [teamId], references: [id], onDelete: SetNull)
  matchParticipants TournamentMatchParticipant[]
  resultSubmissions MatchResultSubmission[]
  leaderboardEntries TournamentLeaderboardEntry[]
  disputes        TournamentDispute[]
  payouts         TournamentPayout[]

  @@index([tournamentId, status])
  @@index([tournamentId, checkinStatus])
  @@unique([tournamentId, userId])
  @@unique([tournamentId, teamId])
}

model TournamentMatch {
  id             String   @id @default(cuid())
  tournamentId    String
  roundNo        Int
  matchIndex     Int?
  groupNo        Int?
  roomId         String?
  roomPass       String?
  scheduledAt    DateTime?
  status         String   @default("SCHEDULED") // SCHEDULED | LIVE | FINISHED | CANCELLED
  formatSnapshot String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  participants   TournamentMatchParticipant[]
  resultSubmissions MatchResultSubmission[]
  disputes        TournamentDispute[]

  @@index([tournamentId, roundNo])
  @@index([tournamentId, status])
}

model TournamentMatchParticipant {
  id             String   @id @default(cuid())
  matchId         String
  registrationId  String
  slotNo         Int?
  joined         Boolean  @default(false)
  isWinner       Boolean?
  score          Float?
  placement      Int?
  kills          Int?
  seed           Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  match          TournamentMatch         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  registration   TournamentRegistration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([matchId, registrationId])
  @@index([registrationId])
}

model MatchResultSubmission {
  id               String   @id @default(cuid())
  matchId           String
  registrationId    String
  submittedByUserId String?
  proofUrl          String?
  proofMeta         Json?
  placement         Int?
  kills             Int?
  roundWins         Int?
  roundLosses       Int?
  score             Float?
  scoreBreakdown    Json?
  verifiedStatus    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  verifiedByUserId  String?
  verifierNote      String?
  submittedAt       DateTime @default(now())
  verifiedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  match             TournamentMatch         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  registration      TournamentRegistration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  submittedBy       User?                   @relation("ResultSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)

  @@index([matchId, verifiedStatus])
  @@index([registrationId])
}

model TournamentLeaderboardEntry {
  id             String   @id @default(cuid())
  tournamentId    String
  registrationId  String
  rank           Int?
  points         Float    @default(0)
  kills          Int      @default(0)
  placementPoints Float   @default(0)
  bonusPoints    Float    @default(0)
  matchesPlayed  Int      @default(0)
  wins           Int      @default(0)
  lastCalculatedAt DateTime @default(now())
  snapshotMeta   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tournament     Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  registration   TournamentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, registrationId])
  @@index([tournamentId, rank])
}

model TournamentDispute {
  id               String   @id @default(cuid())
  tournamentId      String
  matchId           String
  registrationId    String?
  raisedByUserId    String
  reason            String
  details           String?
  evidenceUrl       String?
  status            String   @default("OPEN") // OPEN | REVIEWING | RESOLVED | REJECTED
  resolutionNote    String?
  resolvedByUserId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  resolvedAt        DateTime?

  tournament        Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  match             TournamentMatch        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  registration      TournamentRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  raisedBy          User                   @relation("DisputeRaisedBy", fields: [raisedByUserId], references: [id], onDelete: Cascade)

  @@index([tournamentId, status])
  @@index([matchId])
}

model TournamentPayout {
  id               String   @id @default(cuid())
  tournamentId      String
  registrationId    String?
  userId            String
  amount            Float
  currency          String   @default("NPR")
  rank              Int?
  reason            String?
  status            String   @default("PENDING") // PENDING | SENT | FAILED | CANCELLED
  method            String?  // wallet | manual
  reference         String?
  initiatedByUserId String?
  processedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tournament        Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  registration      TournamentRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tournamentId, status])
  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Float
  status      String   @default("pending")
  method      String?
  reference   String?
  screenshot  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id])
}

model UserPushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model BroadcastNotification {
  id              String   @id @default(cuid())
  title           String
  message         String
  type            String   @default("NORMAL") // NORMAL | BANNER | POPUP
  bannerImageUrl  String?
  target          String   @default("ALL")
  showAsPopup     Boolean  @default(false)
  allowDontShowAgain Boolean @default(true)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy       User?    @relation("BroadcastCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  popupDismissals BroadcastPopupDismissal[]

  @@index([createdAt])
}

model BroadcastPopupDismissal {
  id          String   @id @default(cuid())
  userId      String
  broadcastId String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  broadcast   BroadcastNotification @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([userId, broadcastId])
  @@index([broadcastId])
}

model UserNotification {
  id                String   @id @default(cuid())
  userId            String
  category          String   @default("SYSTEM") // SYSTEM | WALLET | TOURNAMENT | CUSTOM | BROADCAST
  title             String
  message           String
  metadata          Json?
  imageUrl          String?
  isRead            Boolean  @default(false)
  readAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

model PaymentQR {
  id          String   @id @default(cuid())
  method      String   @unique
  qrImage     String
  accountName String?
  accountNumber String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppConfig {
  id                   String   @id @default("global")
  minDepositAmount     Float    @default(100)
  minWithdrawalAmount  Float    @default(100)
  systemSetupBalance   Float    @default(50000)
  autoApprovePayments  Boolean  @default(false)
  customOdd1v1         Float    @default(1.8)
  customOdd2v2         Float    @default(1.8)
  customOdd3v3         Float    @default(1.8)
  customOdd4v4         Float    @default(1.8)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model BlockedUser {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String
  createdAt   DateTime @default(now())
  
  blocker     User     @relation("BlockedBy", fields: [blockerId], references: [id])
  blocked     User     @relation("Blocked", fields: [blockedId], references: [id])
  
  @@unique([blockerId, blockedId])
}

model CustomMatch {
  id                 String   @id @default(cuid())
  createdByUserId    String
  title              String
  roomType           String   // CUSTOM_ROOM | LONE_WOLF
  mode               String   // 1v1 | 2v2 | 3v3 | 4v4
  rounds             Int
  entryFee           Float    @default(0)
  defaultCoin        Int      @default(9950)
  throwableLimit     Boolean  @default(false)
  characterSkill     Boolean  @default(false)
  allSkillsAllowed   Boolean  @default(true)
  selectedSkills     Json?
  headshotOnly       Boolean  @default(true)
  gunAttributes      Boolean  @default(false)
  maxPlayers         Int      @default(2)
  roomId             String?
  roomPassword       String?
  status             String   @default("OPEN") // OPEN | ACTIVE | FULL | CLOSED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  createdBy          User     @relation("CustomMatchCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  joinRequests       CustomMatchJoinRequest[]
  participants       CustomMatchParticipant[]
  resultSubmissions  CustomMatchResultSubmission[]

  @@index([createdByUserId, createdAt])
  @@index([status, createdAt])
}

model CustomMatchJoinRequest {
  id               String   @id @default(cuid())
  customMatchId    String
  userId           String
  status           String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customMatch      CustomMatch @relation(fields: [customMatchId], references: [id], onDelete: Cascade)
  user             User        @relation("CustomMatchJoinRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy       User?       @relation("CustomMatchJoinReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([customMatchId, userId])
  @@index([customMatchId, status])
}

model CustomMatchParticipant {
  id            String   @id @default(cuid())
  customMatchId String
  userId        String
  slotNo        Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customMatch   CustomMatch @relation(fields: [customMatchId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([customMatchId, userId])
  @@index([customMatchId])
}

model CustomMatchResultSubmission {
  id               String   @id @default(cuid())
  customMatchId    String
  submittedByUserId String
  winnerUserId     String
  proofUrl         String
  status           String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewerUserId   String?
  reviewNote       String?
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customMatch      CustomMatch @relation(fields: [customMatchId], references: [id], onDelete: Cascade)
  submittedBy      User        @relation("CustomMatchResultSubmitter", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  winner           User        @relation("CustomMatchResultWinner", fields: [winnerUserId], references: [id], onDelete: Cascade)
  reviewer         User?       @relation("CustomMatchResultReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([customMatchId, status])
  @@index([winnerUserId, status])
}

model Match {
  id                String      @id @default(uuid()) @db.Uuid
  creatorId         String
  joinerId          String?
  gameName          String      @default("Free Fire")
  roomType          String      @default("CUSTOM_ROOM")
  matchType         String      @default("1v1")
  rounds            Int         @default(7)
  defaultCoin       Int         @default(9950)
  throwableLimit    Boolean     @default(false)
  characterSkill    Boolean     @default(false)
  allSkillsAllowed  Boolean     @default(true)
  selectedSkills    Json?
  headshotOnly      Boolean     @default(true)
  gunAttributes     Boolean     @default(false)
  entryFee          Decimal     @db.Decimal(18, 2)
  prizePool         Decimal     @db.Decimal(18, 2)
  status            MatchStatus @default(OPEN)
  roomIdEncrypted   String?
  roomPassEncrypted String?
  expiresAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  creator           User        @relation("MatchCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  joiner            User?       @relation("MatchJoiner", fields: [joinerId], references: [id], onDelete: SetNull)
  joinRequests      JoinRequest[]
  escrows           Escrow[]
  walletLedger      WalletLedger[]
  logs              MatchLog[]
  resultClaims      MatchResultClaim[] @relation("MatchResultClaims")
  chatMessages      ChatMessage[]
  fraudFlags        FraudFlag[]

  @@index([status, createdAt])
  @@index([creatorId, createdAt])
  @@index([joinerId, createdAt])
}

model JoinRequest {
  id        String            @id @default(uuid()) @db.Uuid
  matchId   String            @db.Uuid
  joinerId  String
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  match     Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  joiner    User              @relation(fields: [joinerId], references: [id], onDelete: Cascade)

  @@index([matchId, status])
  @@unique([matchId, joinerId])
}

model Escrow {
  id          String       @id @default(uuid()) @db.Uuid
  matchId     String       @db.Uuid
  totalAmount Decimal      @db.Decimal(18, 2)
  status      EscrowStatus @default(LOCKED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  match       Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, status])
}

model WalletLedger {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String
  matchId      String?          @db.Uuid
  type         WalletLedgerType
  amount       Decimal          @db.Decimal(18, 2)
  balanceAfter Decimal          @db.Decimal(18, 2)
  createdAt    DateTime         @default(now())

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  match        Match?           @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model MatchLog {
  id          String   @id @default(uuid()) @db.Uuid
  matchId     String   @db.Uuid
  action      String
  performedBy String?
  meta        Json?
  createdAt   DateTime @default(now())

  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  performer   User?    @relation("PerformedBy", fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([matchId, createdAt])
}

model MatchResultClaim {
  id              String   @id @default(uuid()) @db.Uuid
  matchId         String   @db.Uuid
  submittedBy     String
  claimedWinnerId String
  proofUrl        String?
  note            String?
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  match           Match    @relation("MatchResultClaims", fields: [matchId], references: [id], onDelete: Cascade)
  submitter       User     @relation("ResultClaimSubmitter", fields: [submittedBy], references: [id], onDelete: Cascade)
  claimedWinner   User     @relation("ResultClaimWinner", fields: [claimedWinnerId], references: [id], onDelete: Cascade)

  @@index([matchId, submittedBy])
  @@unique([matchId, submittedBy])
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  matchId   String   @db.Uuid
  senderId  String
  message   String
  createdAt DateTime @default(now())

  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
}

model FraudFlag {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String
  matchId   String   @db.Uuid
  reason    String
  ip        String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([matchId, createdAt])
}

model RefreshToken {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String
  tokenHash   String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model UserRewardState {
  userId            String   @id
  lastDailyClaimAt  DateTime?
  streak            Int      @default(0)
  lastSpinAt        DateTime?
  spinTokens        Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RewardSpin {
  id             String   @id @default(cuid())
  userId         String
  rewardType     String
  rewardValue    Int
  createdAt      DateTime @default(now())
  clientSeed     String?
  serverSeedHash String?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RewardAudit {
  id          String   @id @default(cuid())
  userId      String
  action      String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}
