{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001 -H 0.0.0.0",
    "predev:socket": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev:socket": "node server/socket-server.mjs",
    "build": "next build",
    "start": "next start -p 3001 -H 0.0.0.0",
    "start:socket": "cross-env NODE_ENV=production node server/socket-server.mjs",
    "worker:match-timeout": "tsx workers/match-timeout-worker.ts",
    "worker:match-timeout:bullmq": "tsx workers/match-timeout-bullmq.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@upstash/redis": "^1.34.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.48.1",
    "cloudinary": "^2.5.0",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^9.14.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.0",
    "nodemailer": "^6.9.15",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.16.0",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^18.3.0",
    "cross-env": "^7.0.3",
    "prisma": "^5.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
